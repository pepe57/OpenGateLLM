{
  "name": "@proj-airi/lobe-icons",
  "type": "module",
  "version": "1.0.18",
  "description": "Iconify JSON IconSet port for @lobehub/icons",
  "author": {
    "name": "Project AIRI Team",
    "email": "airi-team@moeru.ai",
    "url": "https://github.com/proj-airi"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proj-airi/iconify-lobe-icons.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./icons.json": "./dist/icons.json",
    "./info.json": "./dist/info.json",
    "./metadata.json": "./dist/metadata.json",
    "./*": "./*"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "dependencies": {
    "@iconify/types": "^2.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.1",
    "@iconify/tools": "^5.0.0",
    "@lobehub/icons-static-svg": "^1.74.0",
    "@types/node": "^25.0.2",
    "bumpp": "^10.3.2",
    "changelogithub": "^14.0.0",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "local-pkg": "^1.1.2",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.9.2",
    "tsdown": "^0.17.4",
    "typescript": "^5.9.3",
    "unplugin-unused": "^0.5.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "scripts": {
    "dev": "tsdown",
    "stub": "tsdown",
    "build": "tsdown",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "typecheck": "tsc --noEmit",
    "sizecheck": "npx vite-bundle-visualizer",
    "up": "taze -w -r -I -f && pnpm prune && pnpm dedupe",
    "changelogithub": "changelogithub"
  }
}